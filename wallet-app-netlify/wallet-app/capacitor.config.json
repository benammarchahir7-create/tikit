{
  "appId": "com.tonnom.walletapp",
  "appName": "Wallet",
  "webDir": "build",
  "server": {
    "androidScheme": "https"
  },
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#050505",
    "preferredContentMode": "mobile",
    "limitsNavigationsToAppBoundDomains": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "backgroundColor": "#050505",
      "showSpinner": false
    }
  }
}
